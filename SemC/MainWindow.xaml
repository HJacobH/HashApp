<Window x:Class="SemC.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SemC"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Název obce (Klíč):" FontWeight="Bold"/>
            <TextBox x:Name="txtName" Margin="0,0,0,10" Padding="2"/>

            <TextBlock Text="Počet obyvatel:"/>
            <TextBox x:Name="txtPop" Margin="0,0,0,10" Padding="2"/>

            <TextBlock Text="Rozloha (km²):"/>
            <TextBox x:Name="txtArea" Margin="0,0,0,10" Padding="2"/>

            <Button Content="Vložit obec" Click="BtnInsert_Click" Margin="0,0,0,5" Padding="5"/>
            <Button Content="Vyhledat obec" Click="BtnSearch_Click" Margin="0,0,0,5" Padding="5"/>
            <Button Content="Smazat obec" Click="BtnDelete_Click" Margin="0,0,0,15" Padding="5"/>

            <TextBlock Text="Generování dat:" FontWeight="Bold"/>
            <Button Content="Generovat 10 000 obcí" Click="BtnGenerate_Click" Margin="0,0,0,5" Padding="5"/>

            <Button Content="Vypsat všechny obce" Click="BtnPrintAll_Click" Margin="0,15,0,5" Padding="5"/>

            <TextBlock Text="Statistiky I/O operací:" FontWeight="Bold" Margin="0,15,0,5"/>
            <TextBlock x:Name="txtStats" Text="Čtení bloků: 0&#x0a;Zápis bloků: 0" Foreground="Blue"/>
        </StackPanel>

        <ListBox x:Name="lstOutput" Grid.Column="1" FontFamily="Consolas"/>
    </Grid>
</Window>
